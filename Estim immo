const $=id=>document.getElementById(id);
const esc=s=>String(s??'').replace(/&/g,'&amp;').replace(/</g,'&lt;');
const shuffle=a=>{const b=[...a];for(let i=b.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[b[i],b[j]]=[b[j],b[i]];}return b;};
const COLORS=['#7c3aed','#06b6d4','#10b981','#f59e0b','#ef4444','#ec4899','#8b5cf6','#14b8a6'];
const avC=n=>COLORS[(n||'a').charCodeAt(0)%COLORS.length];
const avI=n=>(n||'?')[0].toUpperCase();
const ROUNDS=6,TIMER=30,PTS=[100,70,50,35,25,15,10,5];
let G={players:[],round:0,listings:[],cur:null,estimates:{},pidx:0,photoIdx:0,timer:null,timerEnd:0,totalScore:{}};

function showMenu(){$('menuScreen').style.display='flex';$('setupScreen').classList.remove('active');$('gameScreen').classList.remove('active');}
function showSetup(){$('menuScreen').style.display='none';$('setupScreen').classList.add('active');}
function showGame(){$('menuScreen').style.display='none';$('setupScreen').classList.remove('active');$('gameScreen').classList.add('active');}
function backToMenu(){$('finalOverlay').classList.remove('active');$('resultOverlay').classList.remove('active');G={players:[],round:0,listings:[],cur:null,estimates:{},pidx:0,photoIdx:0,timer:null,timerEnd:0,totalScore:{}};players=[];renderChips();$('btnStartGame').disabled=true;showMenu();}
window.showMenu=showMenu;window.backToMenu=backToMenu;

let players=[];
$('btnMenuLocal').onclick=showSetup;
$('btnMenuOnline').onclick=()=>alert('Mode en ligne bientôt disponible !');
$('btnAddPlayer').onclick=addPlayer;
$('playerInput').onkeydown=e=>{if(e.key==='Enter')addPlayer();};
function addPlayer(){const inp=$('playerInput');const n=(inp.value||'').trim();if(!n||players.length>=8)return;if(players.some(p=>p.toLowerCase()===n.toLowerCase()))return;players.push(n);inp.value='';inp.focus();renderChips();$('btnStartGame').disabled=players.length<2;}
function removePlayer(i){players.splice(i,1);renderChips();$('btnStartGame').disabled=players.length<2;}
window.removePlayer=removePlayer;
function renderChips(){$('playerChips').innerHTML=players.map((p,i)=>`<div class="player-chip"><span class="ps-av" style="background:${avC(p)}">${avI(p)}</span>${esc(p)}<span class="x" onclick="removePlayer(${i})">✕</span></div>`).join('')||'<span style="color:#555;font-size:.82rem">Ajoute au moins 2 joueurs</span>';}
renderChips();

$('btnStartGame').onclick=()=>{if(players.length<2)return;G.players=players.map((n,i)=>({name:n,id:'p'+i,score:0}));G.listings=shuffle(LISTINGS).slice(0,ROUNDS);G.round=0;G.totalScore={};G.players.forEach(p=>G.totalScore[p.id]=0);showGame();startRound();};

function startRound(){G.round++;if(G.round>ROUNDS){showFinal();return;}G.cur=G.listings[G.round-1];G.estimates={};G.pidx=0;G.photoIdx=0;$('roundPill').textContent=G.round+' / '+ROUNDS;renderAnnonce();renderMap();renderPlayers();showTurn(0);}
function renderAnnonce(){const l=G.cur;$('photoImg').src=l.photos[0];$('photoCounter').textContent='1 / '+l.photos.length;$('infoBadges').innerHTML=`<div class="info-badge surface">${l.surface} m²</div><div class="info-badge pieces">${l.pieces} pièce${l.pieces>1?'s':''}</div><div class="info-badge type">${l.type}</div>`;$('infoCity').textContent=l.city;$('infoRegion').textContent=l.region;$('infoFeatures').innerHTML=l.features.map(f=>`<span class="info-feat">${esc(f)}</span>`).join('');$('infoDesc').textContent=l.desc;}
function renderMap(){const l=G.cur;$('mapFrame').src=`https://www.openstreetmap.org/export/embed.html?bbox=${l.lng-.012},${l.lat-.007},${l.lng+.012},${l.lat+.007}&layer=mapnik&marker=${l.lat},${l.lng}`;}
$('photoPrev').onclick=()=>{G.photoIdx=(G.photoIdx-1+G.cur.photos.length)%G.cur.photos.length;updPhoto();};
$('photoNext').onclick=()=>{G.photoIdx=(G.photoIdx+1)%G.cur.photos.length;updPhoto();};
function updPhoto(){$('photoImg').src=G.cur.photos[G.photoIdx];$('photoCounter').textContent=(G.photoIdx+1)+' / '+G.cur.photos.length;}
function renderPlayers(){$('playersStrip').innerHTML=G.players.map(p=>{const done=p.id in G.estimates;const cur=G.players[G.pidx]?.id===p.id&&!done;return`<div class="ps-player ${done?'done':''} ${cur?'current':''}"><span class="ps-av" style="background:${avC(p.name)}">${avI(p.name)}</span>${esc(p.name)}<span class="ps-dot ${done?'done':'waiting'}"></span></div>`;}).join('');}

function showTurn(idx){if(idx>=G.players.length){showResult();return;}G.pidx=idx;renderPlayers();const p=G.players[idx];$('turnTitle').textContent=p.name+', c\'est ton tour !';$('turnSub').textContent='Regarde l\'annonce et estime le loyer mensuel';$('turnOverlay').classList.add('active');$('btnReady').onclick=()=>{$('turnOverlay').classList.remove('active');startEstim(idx);};}
function startEstim(idx){const p=G.players[idx];$('estimLabel').textContent=p.name+' — Votre estimation';$('scorePill').textContent=G.totalScore[p.id]+' Pts';$('estimInput').value='';$('estimInput').disabled=false;$('btnValidate').disabled=false;$('estimInput').focus();startTimer();}
function startTimer(){clearInterval(G.timer);G.timerEnd=Date.now()+TIMER*1000;G.timer=setInterval(()=>{const ms=Math.max(0,G.timerEnd-Date.now());const s=Math.ceil(ms/1000);const pct=(ms/(TIMER*1000))*100;const fill=$('timerFill');fill.style.width=pct+'%';$('timerNum').textContent=s;fill.className='timer-bar-fill'+(s<=5?' urgent':s<=10?' warn':'');if(ms<=0){clearInterval(G.timer);submitEstim(null);}},80);}
$('btnValidate').onclick=()=>{const v=parseInt($('estimInput').value);if(isNaN(v)||v<0)return;submitEstim(v);};
$('estimInput').onkeydown=e=>{if(e.key==='Enter')$('btnValidate').click();};
function submitEstim(val){clearInterval(G.timer);$('estimInput').disabled=true;$('btnValidate').disabled=true;const p=G.players[G.pidx];G.estimates[p.id]=val??0;renderPlayers();setTimeout(()=>showTurn(G.pidx+1),600);}

function showResult(){const real=G.cur.price;$('resultPrice').textContent=real+' €/mois';const ranked=G.players.map(p=>{const g=G.estimates[p.id]||0;return{...p,guess:g,diff:Math.abs(g-real)};}).sort((a,b)=>a.diff-b.diff);ranked.forEach((r,i)=>{const pts=PTS[i]||0;r.pts=pts;G.totalScore[r.id]+=pts;});$('resultGrid').innerHTML=ranked.map((r,i)=>{const d=.5+i*.35;const pct=real>0?Math.round((r.diff/real)*100):0;return`<div class="rank-row ${i===0?'gold':''}" style="animation:slideUp .5s cubic-bezier(.34,1.56,.64,1) ${d}s forwards"><span class="rank-pos p${i+1}">#${i+1}</span><div class="rank-av" style="background:${avC(r.name)}">${avI(r.name)}</div><div class="rank-info"><div class="rank-name">${esc(r.name)}</div><div class="rank-guess">Estimation : ${r.guess} €</div></div><span class="rank-diff ${pct<15?'close':'far'}">Δ ${r.diff} €</span><span class="rank-pts">+${r.pts}</span></div>`;}).join('');$('btnNextRound').textContent=G.round>=ROUNDS?'Voir les résultats →':'Manche suivante →';$('resultOverlay').classList.add('active');}
$('btnNextRound').onclick=()=>{$('resultOverlay').classList.remove('active');startRound();};

function showFinal(){const sorted=G.players.map(p=>({...p,score:G.totalScore[p.id]})).sort((a,b)=>b.score-a.score);$('finalTitle').textContent='🏆 '+sorted[0].name+' remporte la partie !';$('finalSub').textContent=ROUNDS+' manches · '+G.players.length+' joueurs';const pod=sorted.length>=3?[sorted[1],sorted[0],sorted[2]]:sorted.length>=2?[sorted[1],sorted[0]]:sorted;const pos=sorted.length>=3?[2,1,3]:sorted.length>=2?[2,1]:[1];$('podium').innerHTML=pod.map((p,i)=>{const ps=pos[i];const d=.3+ps*.3;return`<div class="pod-item" style="animation:slideUp .6s cubic-bezier(.34,1.56,.64,1) ${d}s forwards"><div class="pod-av" style="background:${avC(p.name)}">${avI(p.name)}</div><div class="pod-name">${esc(p.name)}</div><div class="pod-bar p${ps}"><div class="pod-pts">${p.score}</div><div style="font-size:.7rem;color:#888;margin-top:4px">#${ps}</div></div></div>`;}).join('');$('finalExtra').innerHTML=sorted.slice(3).map((p,i)=>`<div class="rank-row" style="animation:slideUp .4s ease ${1.5+i*.2}s forwards"><span class="rank-pos">#${i+4}</span><div class="rank-av" style="background:${avC(p.name)}">${avI(p.name)}</div><div class="rank-info"><div class="rank-name">${esc(p.name)}</div></div><span class="rank-pts">${p.score} pts</span></div>`).join('');const cw=$('confettiWrap');cw.innerHTML='';const cols=['#ff6b2b','#fbbf24','#22c55e','#3b82f6','#ec4899','#7c3aed'];for(let i=0;i<80;i++){const e=document.createElement('div');e.className='confetti';e.style.cssText=`left:${Math.random()*100}%;background:${cols[i%cols.length]};animation-duration:${1.2+Math.random()*2}s;animation-delay:${Math.random()}s;width:${5+Math.random()*8}px;height:${5+Math.random()*8}px;border-radius:${Math.random()>.5?'50%':'2px'}`;cw.appendChild(e);}$('finalOverlay').classList.add('active');}
$('btnGameMenu').onclick=()=>{if(confirm('Quitter la partie ?'))backToMenu();};
</script>
</body>
